{
  "name": "opencode-gateway",
  "version": "0.1.0",
  "description": "OpenCode with a messaging front door.",
  "module": "dist/index.js",
  "type": "module",
  "bin": {
    "opencode-gateway": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "SPEC.md"
  ],
  "scripts": {
    "build": "bun run scripts/build.ts",
    "build:bin": "bun run scripts/build.ts --binary",
    "build:all": "bun run scripts/build.ts --all",
    "dev": "bun --watch index.ts serve",
    "prepack": "bun run build",
    "serve": "bun index.ts serve",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.16.2",
    "grammy": "^1.43.0",
    "jsonc-parser": "^3.3.1",
    "zod": "^4.4.3"
  }
}
