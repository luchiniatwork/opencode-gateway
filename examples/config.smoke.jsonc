{
  // Real smoke config for normal gateway and optional permission UX acceptance.
  // Required environment:
  // - TELEGRAM_BOT_TOKEN: token from BotFather
  // - TELEGRAM_ALLOW_FROM: numeric Telegram user id allowed to use the bot
  // - OPENAI_API_KEY: OpenAI API key available to the attached OpenCode server
  "gateway": {
    "host": "127.0.0.1",
    "port": 8765,
    "databasePath": "~/.opencode-gateway/smoke-state.db",
    "logLevel": "info"
  },
  "opencode": {
    "targets": [
      {
        "id": "default",
        "name": "Local OpenCode",
        "mode": "attach",
        "serverUrl": "http://127.0.0.1:4096",
        "workdir": "./opencode-smoke",
        "defaultModel": "openai/gpt-5.5"
      }
    ]
  },
  "profiles": {
    "default": "default",
    "entries": [
      {
        "id": "default",
        "displayName": "Default",
        "description": "Real smoke profile",
        "defaultTarget": "default",
        "defaultModel": "openai/gpt-5.5",
        "defaults": { "verbosity": "compact", "busyMode": "queue" }
      },
      {
        "id": "permission-smoke",
        "displayName": "Permission Smoke",
        "description": "Triggers OpenCode permission requests for Telegram approval smoke tests",
        "defaultTarget": "default",
        "defaultAgent": "permission-smoke",
        "defaultModel": "openai/gpt-5.5",
        "defaults": { "verbosity": "tools", "busyMode": "queue" }
      }
    ]
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "{env:TELEGRAM_BOT_TOKEN}",
      "allowFrom": ["{env:TELEGRAM_ALLOW_FROM}"],
      "groups": {}
    }
  },
  "interactive": {
    "permissions": {
      "mode": "buttons",
      "fallbackCommands": true,
      // Enabled for the smoke config so the "Always allow" button is visible
      // during permission UX validation.
      "allowAlways": true
    }
  },
  "defaults": {
    "profile": "default",
    "target": "default",
    "busyMode": "queue",
    "verbosity": "compact",
    "inboundDebounceMs": 1500
  }
}
